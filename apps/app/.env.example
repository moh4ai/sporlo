NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOi...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOi...

# Public URL used when building the member portal magic link.
NEXT_PUBLIC_APP_URL=https://sporlo-app.vercel.app

# Moyasar — test mode keys are fine for dev; production keys land after KYC.
# Without these, the Memberships UI hides the Moyasar payment option and falls
# back to manual recording.
NEXT_PUBLIC_MOYASAR_PUBLISHABLE_KEY=pk_test_...
MOYASAR_SECRET_KEY=sk_test_...
MOYASAR_WEBHOOK_SECRET=set-in-moyasar-dashboard

# Resend — for the member portal magic-link email. Without these, the link is
# generated and copied to clipboard but no email is sent.
RESEND_API_KEY=re_...
RESEND_FROM=Sporlo <noreply@sporlo.net>

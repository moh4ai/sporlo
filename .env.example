# Workspace-level env example. Apps and packages should each have their own
# .env.example documenting only what they read.
#
# Supabase (used by @sporlo/db and apps/app):
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOi...
# Service role key — server-only. NEVER expose to the browser bundle.
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOi...
